@page "/Organization"
@using ComandaOnline.Components.Layout
@using ComandaOnline.Models
@inject NavigationManager Navigation
@layout EmptyLayout
@inject AppDbContext DbContext


<MudPaper Height="80vh" class="d-flex " Elevation="0">
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-auto mb-auto">
        <MudForm>
            <MudPaper Elevation="20" class="pa-8">
                <MudText Typo="Typo.h6" Class="mb-4">Crie ou entre para uma organização</MudText>
                <MudTextField T="string" bind-Value="@_organization.Key" Class="mb-4" Label="Chave da Organização"></MudTextField>
                <MudTextField T="string" bind-Value="@_organization.Name" Class="mb-4" Label="Nome"></MudTextField>
                <MudTextField T="string"  Class="mb-4" Label="Proprietário"></MudTextField>
                
            
                <MudButton Variant="Variant.Filled" Color="Color.Primary">Gerar Nova Organização</MudButton>

            </MudPaper>
        </MudForm>

    </MudContainer>
</MudPaper>



@code {
    OrganizationModel _organization = new OrganizationModel();


}